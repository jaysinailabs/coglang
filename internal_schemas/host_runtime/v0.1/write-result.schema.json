{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:coglang:host-runtime:v0.1:write-result",
  "title": "WriteResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "correlation_id",
    "submission_id",
    "owner",
    "commit_timestamp",
    "applied_ops",
    "phase_counts",
    "touched_node_ids",
    "touched_edge_refs"
  ],
  "properties": {
    "correlation_id": {
      "type": "string"
    },
    "submission_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "commit_timestamp": {
      "type": "string"
    },
    "applied_ops": {
      "type": "integer",
      "minimum": 0
    },
    "phase_counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "touched_node_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "touched_edge_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        }
      }
    }
  }
}
