{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CogLang",
  "scopeName": "source.coglang",
  "fileTypes": ["coglang"],
  "patterns": [
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#variables" },
    { "include": "#heads" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.coglang",
          "match": "\"([^\"\\\\]|\\\\.)*\""
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.coglang",
          "match": "(?<![A-Za-z0-9_])-?(?:[0-9]+(?:\\.[0-9]*)?|\\.[0-9]+)(?![A-Za-z0-9_])"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.parameter.coglang",
          "match": "(?<![A-Za-z0-9_])(?:[A-Za-z][A-Za-z0-9_]*_|_)(?![A-Za-z0-9_])"
        }
      ]
    },
    "heads": {
      "patterns": [
        {
          "name": "entity.name.function.coglang",
          "match": "\\b[A-Za-z](?:[A-Za-z0-9_]*[A-Za-z0-9])?\\b(?=\\s*\\[)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.brackets.coglang",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.section.dictionary.coglang",
          "match": "[{}]"
        },
        {
          "name": "punctuation.separator.coglang",
          "match": "[,:]"
        }
      ]
    }
  }
}
