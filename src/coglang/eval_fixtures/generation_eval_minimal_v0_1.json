{
  "schema_version": "coglang-generation-eval-fixture/v0.1",
  "name": "minimal-l1-l3-offline-generation-eval",
  "description": "Fifty offline prompt cases for deterministic CogLang generation scoring. This fixture does not call an external model and is not a benchmark claim.",
  "defined_levels": ["L1", "L2", "L3", "L4", "L5", "L6"],
  "cases": [
    {"case_id": "L1-001", "level": "L1", "prompt": "Return a CogLang expression that checks whether 1 equals 1.", "reference_expr": "Equal[1, 1]", "expected_top_level_heads": ["Equal"]},
    {"case_id": "L1-002", "level": "L1", "prompt": "Return a CogLang expression that compares two different labels.", "reference_expr": "Equal[\"cat\", \"dog\"]", "expected_top_level_heads": ["Equal"]},
    {"case_id": "L1-003", "level": "L1", "prompt": "Return a CogLang expression that structurally compares two dictionaries.", "reference_expr": "Compare[{\"a\": 1}, {\"a\": 2}]", "expected_top_level_heads": ["Compare"]},
    {"case_id": "L1-004", "level": "L1", "prompt": "Return a CogLang expression that reads the name field from a dictionary.", "reference_expr": "Get[{\"name\": \"Ada\"}, \"name\"]", "expected_top_level_heads": ["Get"]},
    {"case_id": "L1-005", "level": "L1", "prompt": "Return a CogLang expression that reads the first item from a list.", "reference_expr": "Get[List[\"a\", \"b\"], 0]", "expected_top_level_heads": ["Get"]},
    {"case_id": "L1-006", "level": "L1", "prompt": "Return a CogLang conditional that chooses yes when the condition is true.", "reference_expr": "If[True[], \"yes\", \"no\"]", "expected_top_level_heads": ["If"]},
    {"case_id": "L1-007", "level": "L1", "prompt": "Return a CogLang conditional that chooses no when the condition is false.", "reference_expr": "If[False[], \"yes\", \"no\"]", "expected_top_level_heads": ["If"]},
    {"case_id": "L1-008", "level": "L1", "prompt": "Return a CogLang expression that handles a not-found value with a fallback.", "reference_expr": "IfFound[NotFound[], x_, x_, \"missing\"]", "expected_top_level_heads": ["IfFound"]},
    {"case_id": "L1-009", "level": "L1", "prompt": "Return a CogLang sequence with two pure equality checks.", "reference_expr": "Do[Equal[1, 1], Equal[2, 2]]", "expected_top_level_heads": ["Do"]},
    {"case_id": "L1-010", "level": "L1", "prompt": "Return a CogLang expression that traces a pure equality check.", "reference_expr": "Trace[Equal[1, 1]]", "expected_top_level_heads": ["Trace"]},
    {"case_id": "L1-011", "level": "L1", "prompt": "Return a CogLang assertion with a success message.", "reference_expr": "Assert[True[], \"ok\"]", "expected_top_level_heads": ["Assert"]},
    {"case_id": "L1-012", "level": "L1", "prompt": "Return a CogLang unification expression with two variables.", "reference_expr": "Unify[f[X_, b], f[a, Y_]]", "expected_top_level_heads": ["Unify"]},
    {"case_id": "L1-013", "level": "L1", "prompt": "Return a CogLang match expression that binds one variable.", "reference_expr": "Match[f[X_], f[a]]", "expected_top_level_heads": ["Match"]},
    {"case_id": "L1-014", "level": "L1", "prompt": "Return a CogLang list containing two labels.", "reference_expr": "List[\"alpha\", \"beta\"]", "expected_top_level_heads": ["List"]},
    {"case_id": "L1-015", "level": "L1", "prompt": "Return a CogLang expression that asks for an explanation of a traversal.", "reference_expr": "Explain[Traverse[\"einstein\", \"born_in\"]]", "expected_top_level_heads": ["Explain"]},
    {"case_id": "L1-016", "level": "L1", "prompt": "Return a CogLang expression that defers a long task.", "reference_expr": "Defer[\"long_task\"]", "expected_top_level_heads": ["Defer"]},
    {"case_id": "L1-017", "level": "L1", "prompt": "Return a CogLang estimate request for a traversal.", "reference_expr": "Estimate[\"Traverse\", List[\"einstein\", \"born_in\"]]", "expected_top_level_heads": ["Estimate"]},
    {"case_id": "L1-018", "level": "L1", "prompt": "Return a CogLang expression that inspects one node.", "reference_expr": "Inspect[\"einstein\"]", "expected_top_level_heads": ["Inspect"]},
    {"case_id": "L2-001", "level": "L2", "prompt": "Return a CogLang query for nodes whose category is Person.", "reference_expr": "Query[n_, Equal[Get[n_, \"category\"], \"Person\"]]", "expected_top_level_heads": ["Query"]},
    {"case_id": "L2-002", "level": "L2", "prompt": "Return a CogLang traversal from einstein over born_in.", "reference_expr": "Traverse[\"einstein\", \"born_in\"]", "expected_top_level_heads": ["Traverse"]},
    {"case_id": "L2-003", "level": "L2", "prompt": "Return a CogLang expression that lists all visible graph nodes.", "reference_expr": "AllNodes[]", "expected_top_level_heads": ["AllNodes"]},
    {"case_id": "L2-004", "level": "L2", "prompt": "Return a CogLang expression that reads labels for two people.", "reference_expr": "ForEach[List[\"ada\", \"grace\"], x_, Get[x_, \"label\"]]", "expected_top_level_heads": ["ForEach"]},
    {"case_id": "L2-005", "level": "L2", "prompt": "Return a CogLang expression that falls back to unknown when birthplace is absent.", "reference_expr": "IfFound[Traverse[\"einstein\", \"born_in\"], place_, place_, \"unknown\"]", "expected_top_level_heads": ["IfFound"]},
    {"case_id": "L2-006", "level": "L2", "prompt": "Return a CogLang query for Rule nodes with default mode and k 5.", "reference_expr": "Query[n_, Equal[Get[n_, \"type\"], \"Rule\"], {\"mode\": \"default\", \"k\": 5}]", "expected_top_level_heads": ["Query"]},
    {"case_id": "L2-007", "level": "L2", "prompt": "Return a CogLang sequence that reads all nodes then queries active nodes.", "reference_expr": "Do[AllNodes[], Query[n_, Equal[Get[n_, \"status\"], \"active\"]]]", "expected_top_level_heads": ["Do"]},
    {"case_id": "L2-008", "level": "L2", "prompt": "Return a CogLang expression that compares a traversal result with a list.", "reference_expr": "Compare[Traverse[\"einstein\", \"born_in\"], List[\"ulm\"]]", "expected_top_level_heads": ["Compare"]},
    {"case_id": "L2-009", "level": "L2", "prompt": "Return a CogLang expression that traces a Person query.", "reference_expr": "Trace[Query[n_, Equal[Get[n_, \"category\"], \"Person\"]]]", "expected_top_level_heads": ["Trace"]},
    {"case_id": "L2-010", "level": "L2", "prompt": "Return a CogLang assertion that a Person query should find results.", "reference_expr": "Assert[Query[n_, Equal[Get[n_, \"category\"], \"Person\"]], \"expected person\"]", "expected_top_level_heads": ["Assert"]},
    {"case_id": "L2-011", "level": "L2", "prompt": "Return a CogLang abstraction over Einstein and Tesla.", "reference_expr": "Abstract[List[\"einstein\", \"tesla\"]]", "expected_top_level_heads": ["Abstract"]},
    {"case_id": "L2-012", "level": "L2", "prompt": "Return a CogLang probe request with a rule list and context.", "reference_expr": "Probe[List[\"rule\"], {\"context\": \"test\"}]", "expected_top_level_heads": ["Probe"]},
    {"case_id": "L2-013", "level": "L2", "prompt": "Return a CogLang exploration request for a topic with limit 3.", "reference_expr": "Explore[\"topic\", {\"limit\": 3}]", "expected_top_level_heads": ["Explore"]},
    {"case_id": "L2-014", "level": "L2", "prompt": "Return a CogLang expression that resumes a task.", "reference_expr": "Resume[\"task-1\"]", "expected_top_level_heads": ["Resume"]},
    {"case_id": "L2-015", "level": "L2", "prompt": "Return a CogLang merge expression over two lists.", "reference_expr": "Merge[List[\"a\"], List[\"b\"]]", "expected_top_level_heads": ["Merge"]},
    {"case_id": "L2-016", "level": "L2", "prompt": "Return a CogLang instantiation request for a rule.", "reference_expr": "Instantiate[\"Rule\", {\"name\": \"R\"}]", "expected_top_level_heads": ["Instantiate"]},
    {"case_id": "L3-001", "level": "L3", "prompt": "Return a CogLang expression that creates a Person entity named ada.", "reference_expr": "Create[\"Entity\", {\"id\": \"ada\", \"category\": \"Person\"}]", "expected_top_level_heads": ["Create"]},
    {"case_id": "L3-002", "level": "L3", "prompt": "Return a CogLang expression that creates a born_in edge.", "reference_expr": "Create[\"Edge\", {\"from\": \"ada\", \"to\": \"london\", \"relation_type\": \"born_in\"}]", "expected_top_level_heads": ["Create"]},
    {"case_id": "L3-003", "level": "L3", "prompt": "Return a CogLang expression that updates ada's label.", "reference_expr": "Update[\"ada\", {\"label\": \"Ada Lovelace\"}]", "expected_top_level_heads": ["Update"]},
    {"case_id": "L3-004", "level": "L3", "prompt": "Return a CogLang expression that deletes ada.", "reference_expr": "Delete[\"ada\"]", "expected_top_level_heads": ["Delete"]},
    {"case_id": "L3-005", "level": "L3", "prompt": "Return a CogLang expression that deletes a born_in edge.", "reference_expr": "Delete[\"Edge\", {\"from\": \"ada\", \"to\": \"london\", \"relation_type\": \"born_in\"}]", "expected_top_level_heads": ["Delete"]},
    {"case_id": "L3-006", "level": "L3", "prompt": "Return a CogLang sequence that creates ada then updates its label.", "reference_expr": "Do[Create[\"Entity\", {\"id\": \"ada\"}], Update[\"ada\", {\"label\": \"Ada\"}]]", "expected_top_level_heads": ["Do"]},
    {"case_id": "L3-007", "level": "L3", "prompt": "Return a CogLang conditional that creates ok only when equality succeeds.", "reference_expr": "If[Equal[1, 1], Create[\"Entity\", {\"id\": \"ok\"}], NotFound[]]", "expected_top_level_heads": ["If"]},
    {"case_id": "L3-008", "level": "L3", "prompt": "Return a CogLang expression that updates a found friend or returns NotFound.", "reference_expr": "IfFound[Traverse[\"ada\", \"friend\"], friend_, Update[friend_, {\"seen\": \"yes\"}], NotFound[]]", "expected_top_level_heads": ["IfFound"]},
    {"case_id": "L3-009", "level": "L3", "prompt": "Return a CogLang expression that marks two people reviewed.", "reference_expr": "ForEach[List[\"ada\", \"grace\"], person_, Update[person_, {\"status\": \"reviewed\"}]]", "expected_top_level_heads": ["ForEach"]},
    {"case_id": "L3-010", "level": "L3", "prompt": "Return a CogLang host submission expression.", "reference_expr": "Send[\"host\", \"submit\", \"payload\"]", "expected_top_level_heads": ["Send"]},
    {"case_id": "L3-011", "level": "L3", "prompt": "Return a CogLang expression that traces an entity creation.", "reference_expr": "Trace[Create[\"Entity\", {\"id\": \"trace_node\"}]]", "expected_top_level_heads": ["Trace"]},
    {"case_id": "L3-012", "level": "L3", "prompt": "Return a CogLang assertion around entity creation.", "reference_expr": "Assert[Create[\"Entity\", {\"id\": \"assert_node\"}], \"created\"]", "expected_top_level_heads": ["Assert"]},
    {"case_id": "L3-013", "level": "L3", "prompt": "Return a CogLang sequence that deletes old then creates new.", "reference_expr": "Do[Delete[\"old\"], Create[\"Entity\", {\"id\": \"new\"}]]", "expected_top_level_heads": ["Do"]},
    {"case_id": "L3-014", "level": "L3", "prompt": "Return a CogLang expression that creates a draft rule.", "reference_expr": "Create[\"Rule\", {\"id\": \"rule1\", \"confidence\": 0.5}]", "expected_top_level_heads": ["Create"]},
    {"case_id": "L3-015", "level": "L3", "prompt": "Return a CogLang expression that connects Einstein to a rule.", "reference_expr": "Create[\"Edge\", {\"from\": \"einstein\", \"to\": \"rule1\", \"relation_type\": \"follows\"}]", "expected_top_level_heads": ["Create"]},
    {"case_id": "L3-016", "level": "L3", "prompt": "Return a CogLang sequence that creates a draft node then deletes it.", "reference_expr": "Do[Create[\"Entity\", {\"id\": \"draft\"}], Delete[\"draft\"]]", "expected_top_level_heads": ["Do"]}
  ]
